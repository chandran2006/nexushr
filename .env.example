# ============================================================
# NexusHR Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ─── Database ────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/nexushr
DB_USERNAME=nexushr
DB_PASSWORD=nexushr123

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=nexushr-super-secret-jwt-key-2024-enterprise-grade-security-key-minimum-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Mail ────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@nexushr.com
MAIL_PASSWORD=your-app-password

# ─── App ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=uploads
PORT=8080

# ─── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
